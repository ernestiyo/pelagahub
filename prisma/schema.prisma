// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// status is a plain String ("draft" | "published") rather than a Prisma
// enum, enforced at the application layer instead — kept this way even on
// Postgres for simplicity (adding values later needs no migration).
model Module {
  id     String @id @default(cuid())
  slug   String @unique
  order  Int
  title  String
  summary String
  status String @default("draft")
  coverImage String?

  // Hero
  estimatedTime String @default("")

  // Struktur modul (lihat MODULE_GUIDELINES.md): objective checklist,
  // opening story (bubble percakapan), benefit cards, lessons, mini
  // challenge. Tiap lesson di dalam `lessons` membawa field-nya sendiri:
  // apa-itu + analogi, langkah-langkah, contoh nyata, tips, dan
  // kesalahan yang sering terjadi (lihat ModuleLesson di src/lib/modules.ts).
  learningObjectives Json @default("[]")
  openingStory       Json @default("[]")
  benefits           Json @default("[]")
  lessons            Json @default("[]")
  miniChallenge      Json @default("[]")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("modules")
}
